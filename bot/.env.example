# --- Обязательные ---
VK_TOKEN=vk1.a.YOUR_TOKEN_HERE
MY_USER_ID=YOUR_USER_ID

# --- Ключи (выбери один из режимов или оба сразу) ---

# Режим 1: прямые hex-ключи (старый стиль v3.x). Можно несколько.
PRE_SHARED_KEY_K1=your_hex_key_here_64_chars
PRE_SHARED_KEY_K2=your_hex_key_here_64_chars

# Режим 2: seed-фраза, из которой PBKDF2-SHA256 (250k итераций)
#          деривит k1..k4. Должна СОВПАДАТЬ с фразой в userscript'е.
# SEED_PHRASE=длинная секретная фраза

# --- Опционально ---
# Слот, которым бот шифрует ответы. По умолчанию k1.
# DEFAULT_KEY_ID=k1
