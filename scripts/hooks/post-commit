#!/usr/bin/env bash
# Auto-bump patch version и пересборка userscript после любого коммита,
# который трогает extension/vkencrypt.user.js.
#
# Поведение:
#   - Коммит изменил vkencrypt.user.js → читаем текущий @version,
#     инкрементим patch (4.1.2 → 4.1.3), пишем обратно в userscript,
#     гоняем build.sh.
#   - Создаём отдельный коммит "chore(version): bump to vX.Y.Z".
#   - Если последний коммит уже наш bump — выходим (защита от рекурсии).
#
# Минорные/мажорные бампы делаются руками — этот хук только патч.
set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
EXT_DIR="$REPO_ROOT/extension"
USERJS="$EXT_DIR/vkencrypt.user.js"

# 1. Защита от рекурсии
LAST_MSG=$(git log -1 --pretty=%s)
if [[ "$LAST_MSG" == "chore(version):"* ]]; then
    exit 0
fi

# 2. Трогали ли userscript в этом коммите?
if ! git diff-tree --no-commit-id --name-only -r HEAD | grep -qE 'extension/vkencrypt\.user\.js$'; then
    exit 0
fi

# 3. Бампаем patch. Поддерживаем и 2-частные (4.1) и semver (4.1.2).
NEW_VER=$(node -e "
const fs = require('fs');
const c = fs.readFileSync(process.argv[1], 'utf8');
const m = c.match(/@version\s+(\d+)\.(\d+)(?:\.(\d+))?/);
if (!m) { console.error('No @version found'); process.exit(1); }
const major = m[1], minor = m[2];
const patch = m[3] ? parseInt(m[3]) + 1 : 1;
const next = \`\${major}.\${minor}.\${patch}\`;
const re = new RegExp('(@version\\\\s+)' + major + '\\\\.' + minor + '(?:\\\\.\\\\d+)?');
let out = c.replace(re, '\$1' + next);
const re2 = new RegExp('(APP_VERSION\\\\s*=\\\\s*[\\'\\\"])' + major + '\\\\.' + minor + '(?:\\\\.\\\\d+)?');
out = out.replace(re2, '\$1' + next);
fs.writeFileSync(process.argv[1], out);
console.log(next);
" "$USERJS")

# 4. Пересобираем snapshot
(cd "$EXT_DIR" && ./build.sh > /dev/null)

# 5. Коммитим бамп (dist/ в .gitignore, так что только userscript)
git add "$USERJS"
git commit -m "chore(version): bump to v$NEW_VER" > /dev/null

echo "✅ Auto-bumped to v$NEW_VER (hook: scripts/hooks/post-commit)"
